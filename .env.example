# API key for hosted provider (required when KDX_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Provider: anthropic (default) or openai-compatible (Ollama, LM Studio, vLLM)
# KDX_PROVIDER=anthropic

# Optional overrides
KDX_MODEL=claude-sonnet-4-5
KDX_MAX_TOKENS=1024
# KDX_TIMEOUT=30

# OpenAI-compatible / local LLM (when KDX_PROVIDER=openai-compatible)
# KDX_MODEL=llama3.1:8b
# KDX_LOCAL_BASE_URL=http://localhost:11434/v1
# KDX_LOCAL_API_KEY=ollama
# KDX_TIMEOUT=120
