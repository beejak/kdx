# ── Anthropic (default provider) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Provider selection ────────────────────────────────────────────────────────
# Options: anthropic (default) | openai-compatible
# KDX_PROVIDER=anthropic

# ── Model override ────────────────────────────────────────────────────────────
# Anthropic default: claude-sonnet-4-5
# Local default:     llama3.1:8b
# KDX_MODEL=claude-sonnet-4-5

# ── Token / timeout ───────────────────────────────────────────────────────────
# KDX_MAX_TOKENS=1024
# KDX_TIMEOUT=30          # seconds — default 30 for anthropic, 120 for openai-compatible

# ── Local LLM (openai-compatible provider) ────────────────────────────────────
# Uncomment and set KDX_PROVIDER=openai-compatible to use Ollama, LM Studio, or vLLM
# KDX_LOCAL_BASE_URL=http://localhost:11434/v1
# KDX_LOCAL_API_KEY=ollama

# ── Kubernetes ────────────────────────────────────────────────────────────────
# Override if Docker Desktop writes kubeconfig to Windows side (WSL2 users)
# KUBECONFIG=/mnt/c/Users/<YourUser>/.kube/config

# ── Logging ───────────────────────────────────────────────────────────────────
# KDX_LOG_LEVEL=WARNING
